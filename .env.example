# Database Config
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_NAME=your_database_name
DB_SSLMODE=prefer

# Encryption Config
# If ENCRYPTION_PASSWORD is not set, it falls back to DB_PASSWORD for convenience.
ENCRYPTION_PASSWORD=your-secure-encryption-password

# Backup Storage
BACKUP_DIR=backups

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram MTProto (Optional - allows bypassing 50MB file limit)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# MTProto Proxy (Optional - requires API_ID/HASH above)
MTPROTO_PROXY_HOST=
MTPROTO_PROXY_PORT=
MTPROTO_PROXY_SECRET=
