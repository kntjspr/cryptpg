# Database Config
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_NAME=your_database_name
DB_SSLMODE=prefer

# Encryption Config
# If ENCRYPTION_PASSWORD is not set, it falls back to DB_PASSWORD for convenience.
ENCRYPTION_PASSWORD=your-secure-encryption-password

# Backup Storage
BACKUP_DIR=backups

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram MTProto (Optional - allows bypassing 50MB file limit)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# MTProto Proxy (Optional - requires API_ID/HASH above)
MTPROTO_PROXY_HOST=
MTPROTO_PROXY_PORT=
MTPROTO_PROXY_SECRET=

# Route Telegram uploads through Tor network (requires local tor service on 9050)
USE_TOR=false

# Dropbox Storage (Optional)
# short-lived access tokens ("sl." prefix) expire in ~4 hours regardless of dev/prod mode.
# use refresh tokens instead -- they don't expire unless manually revoked.
#
# setup:
#   1. go to https://www.dropbox.com/developers/apps and create an app
#   2. under "OAuth 2", set "Access token expiration" to "No expiration" OR just use refresh tokens
#   3. to get a refresh token, run this once:
#
#      import os, dropbox
#      from dotenv import load_dotenv
#      from dropbox import DropboxOAuth2FlowNoRedirect
#      load_dotenv()
#      APP_KEY = os.environ["DROPBOX_APP_KEY"]
#      APP_SECRET = os.environ["DROPBOX_APP_SECRET"]
#      auth_flow = DropboxOAuth2FlowNoRedirect(APP_KEY, APP_SECRET, token_access_type="offline")
#      print("go to:", auth_flow.start())
#      code = input("enter auth code: ").strip()
#      result = auth_flow.finish(code)
#      print("refresh token:", result.refresh_token)  # store this, it won't expire
#
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# Dropbox destination folder (must start with /, e.g., /backups)
DROPBOX_FOLDER=/backups

# Retention Settings (in days)
# Delete local files older than X days (leave empty to disable)
LOCAL_RETENTION_DAYS=7
# Delete dropbox files older than X days (leave empty to disable)
DROPBOX_RETENTION_DAYS=30
